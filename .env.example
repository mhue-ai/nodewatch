# Timpi NodeWatch — Environment Configuration
# Copy to .env and adjust as needed

# Your domain — Caddy auto-provisions HTTPS via Let's Encrypt
# Set to your actual domain for production (must point to this server)
DOMAIN=nodewatch.clawpurse.ai

# Server port (internal, Caddy proxies to this)
PORT=3000

# Health check interval (cron syntax)
# Default: every 5 minutes
CHECK_INTERVAL=*/5 * * * *

# Connection timeout for node checks (ms)
CHECK_TIMEOUT=5000

# How many days of history to retain
HISTORY_DAYS=30

# Neutaro LCD endpoint (for NFT queries)
NEUTARO_LCD=https://api2.neutaro.io

# Google OAuth Client ID (from console.cloud.google.com)
# Leave empty to disable Google sign-in
GOOGLE_CLIENT_ID=
